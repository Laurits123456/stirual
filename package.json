{
  "name": "stirual",
  "productName": "STIRUAL",
  "version": "0.1.0",
  "description": "A canvas-based desktop workspace for coordinating AI agents, terminals, browsers, and notes.",
  "author": "Laurits",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "powershell -ExecutionPolicy Bypass -File ./scripts/dev.ps1",
    "dev:electron": "cross-env NODE_ENV=development electron-vite dev",
    "dev:win": "powershell -ExecutionPolicy Bypass -File ./scripts/dev.ps1",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit",
    "dist:win": "npm run build && electron-builder --win nsis"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@tailwindcss/vite": "^4.1.18",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "node-pty": "1.1.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "zod": "^4.3.5",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.1",
    "cross-env": "^10.0.0",
    "electron": "40.2.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^4.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.3",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "build": {
    "appId": "com.stirual.app",
    "productName": "STIRUAL",
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "build/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/stirual-icon.png",
      "signAndEditExecutable": false,
      "artifactName": "STIRUAL-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
